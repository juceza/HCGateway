APP_HOST=0.0.0.0
APP_PORT=6644

# Flask debug MUST stay off in production. Any value other than
# 1/true/yes/on (case-insensitive) is treated as off.
APP_DEBUG=false

# Master key that wraps each user's per-record data key (envelope encryption).
# REQUIRED. Without it the server cannot encrypt or decrypt data and will error.
# Keep this OUT of the database and back it up separately — losing it makes all
# stored health data permanently unrecoverable.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_MASTER_KEY=

SENTRY_DSN= #(optional)
FCM_PROJECT_ID= #(optional, but required for push/delete)

# Comma-separated allowlist of browser origins permitted via CORS.
# Leave empty to disable cross-origin browser access entirely (recommended
# unless you run a web dashboard).
CORS_ORIGINS=

# MongoDB root credentials. These are consumed by the `db` container
# (MONGO_INITDB_ROOT_USERNAME / _PASSWORD) and must match the user:pass in
# MONGO_URI below. Set strong, unique values before the first run.
MONGO_INITDB_ROOT_USERNAME=hcgateway
MONGO_INITDB_ROOT_PASSWORD=change-me-to-a-long-random-password

# Connection string used by the API. Host is `db` (the compose service name).
MONGO_URI=mongodb://hcgateway:change-me-to-a-long-random-password@db:27017/hcgateway?authSource=admin

# Path to the built Web UI SPA (the React app's dist/ directory). When set to an
# existing directory, Flask serves the SPA from the same process with an
# index.html fallback for client routes. Leave unset to run as a pure API server
# (behaviour is identical to before the Web UI existed). The Docker image sets
# this automatically; for a local build use the absolute path, e.g.:
#   WEB_DIST=./web/dist
WEB_DIST=
